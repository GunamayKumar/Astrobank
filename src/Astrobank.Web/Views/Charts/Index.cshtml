@model Astrobank.Application.Charts.Queries.ListCharts.PaginatedList<Astrobank.Application.Charts.DTOs.ChartDto>
@{
    ViewData["Title"] = "Charts";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Charts Repository</h2>
    <a asp-action="Create" class="btn btn-primary">Create New Chart</a>
</div>
<form method="get" class="mb-4">
    <div class="input-group">
        <input type="text" name="searchTerm" class="form-control" placeholder="Search charts by name, alias, or place..." value="@ViewData["SearchTerm"]" />
        <button class="btn btn-outline-secondary" type="submit">Search</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>
<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-light">
            <tr>
                <th>Name</th><th>Type</th><th>Birth Date</th><th>Place</th><th>Owner</th><th>Access</th><th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Name @(item.AskingForHelp ? "🆘" : "")</td>
                    <td>@item.ChartTypeName</td><td>@item.BirthDate.ToString("yyyy-MM-dd")</td>
                    <td>@item.BirthPlace</td><td>@item.UserName</td><td>@item.ChartPermissionName</td>
                    <td>
                        <a href="#" class="btn btn-sm btn-outline-info">View</a>
                        <a href="#" class="btn btn-sm btn-outline-primary">Edit</a>
                    </td>
                </tr>
            }
            @if(!Model.Items.Any()) {
                <tr><td colspan="7" class="text-center">No charts found.</td></tr>
            }
        </tbody>
    </table>
</div>
